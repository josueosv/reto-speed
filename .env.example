# Railway inyecta DATABASE_URL automáticamente al añadir el plugin PostgreSQL.
# Para correr localmente, define tu propia conexión:
DATABASE_URL=postgresql://usuario:password@localhost:5432/retospeed

# PIN del operador para el panel de control y el botón de borrado.
ADMIN_PIN=1234

# Puerto (Railway lo asigna solo; en local usa 3000).
PORT=3000
